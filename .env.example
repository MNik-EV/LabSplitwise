# ── Required (Vercel / local / any host) ─────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# ── Optional app defaults ─────────────────────────────────────────────
NEXT_PUBLIC_DEFAULT_LOCALE=fa
NEXT_PUBLIC_DEFAULT_LAB_PER_PERSON=350

# ── Optional: Authentik SSO ───────────────────────────────────────────
# Auth is AUTO-OFF when these are empty (Vercel demo works with no extra config).
# Set ALL four OIDC vars + AUTH_SECRET to enable login.
#
# AUTH_SECRET=          # openssl rand -base64 32
# AUTH_URL=https://your-app.example.com
# AUTH_AUTHENTIK_ID=
# AUTH_AUTHENTIK_SECRET=
# AUTH_AUTHENTIK_ISSUER=https://auth.example.com/application/o/labsplitwise/
#
# Redirect URI: {AUTH_URL}/api/auth/callback/authentik
#
# AUTH_DISABLED=true    # force open access
# AUTH_DISABLED=false   # force SSO (fails if OIDC incomplete)
