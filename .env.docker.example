# Copy: cp .env.docker.example .env

# ── Required ──────────────────────────────────────────────────────────
POSTGRES_USER=labsplitwise
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=labsplitwise
APP_PORT=3000

# ── Optional app defaults ─────────────────────────────────────────────
NEXT_PUBLIC_DEFAULT_LOCALE=fa
NEXT_PUBLIC_DEFAULT_LAB_PER_PERSON=350

# ── Optional: Authentik SSO ───────────────────────────────────────────
# Leave ALL auth vars empty → app runs open (no login), good for trusted LAN.
# Fill ALL auth vars below → Authentik OIDC login required.
#
# AUTH_URL=https://labsplitwise.example.com
# AUTH_SECRET=          # openssl rand -base64 32
# AUTH_AUTHENTIK_ID=
# AUTH_AUTHENTIK_SECRET=
# AUTH_AUTHENTIK_ISSUER=https://auth.example.com/application/o/labsplitwise/
#
# Redirect URI in Authentik: {AUTH_URL}/api/auth/callback/authentik
#
# Force open access even if OIDC vars are set:
# AUTH_DISABLED=true
#
# Force SSO (error on start if OIDC incomplete):
# AUTH_DISABLED=false
