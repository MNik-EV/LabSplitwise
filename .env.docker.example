# Copy to .env and fill in values:
# cp .env.docker.example .env

# PostgreSQL (internal — not exposed to host)
POSTGRES_USER=labsplitwise
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=labsplitwise

# App
APP_PORT=3000
AUTH_URL=https://labsplitwise.example.com

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-random-secret

# Set to true only for local testing without SSO
AUTH_DISABLED=false

# Authentik OIDC provider
# In Authentik: Applications → Create OAuth2/OIDC Provider + Application
# Redirect URI: https://labsplitwise.example.com/api/auth/callback/authentik
AUTH_AUTHENTIK_ID=your-client-id
AUTH_AUTHENTIK_SECRET=your-client-secret
# Issuer URL from Authentik app (trailing slash required)
AUTH_AUTHENTIK_ISSUER=https://auth.example.com/application/o/labsplitwise/

# Optional app defaults
NEXT_PUBLIC_DEFAULT_LOCALE=fa
NEXT_PUBLIC_DEFAULT_LAB_PER_PERSON=350
